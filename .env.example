# Cartograph — No API keys required!
# This file documents available environment variables.
# Copy to .env if you want to override any defaults.

# Ollama host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Model name to use (default: llama3.1)
# CARTOGRAPH_MODEL=llama3.1

# Gradio server port (default: 7860)
# GRADIO_SERVER_PORT=7860
